create procedure getstudentcount(in cid int)
begin
    select count(*) as total_students
    from students
    where class_id = cid;
end //

delimiter ;

call getstudentcount(1);
select s.name, sum(g.marks) as total_marks
from students s
join grades g on s.student_id = g.student_id
group by s.name
having sum(g.marks) > 80;
