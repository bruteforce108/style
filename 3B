create function checkcategory(
    itemid int,
    cat varchar(50)
)
returns varchar(20)
deterministic
begin
    declare result varchar(20);

    select if(category = cat, 'yes', 'no')
    into result
    from menu
    where item_id = itemid;

    return result;
end //

delimiter ;
select checkcategory(1, 'pizza') as result;
