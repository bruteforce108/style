from customers c
join orders o on c.customer_id = o.customer_id
join orderitems oi on o.order_id = oi.order_id
join menu m on oi.item_id = m.item_id
where m.category in ('pizza', 'burgers')
group by c.name
having count(distinct m.category) = 2;
