create procedure patientagegroups()
begin
    select 
        case 
            when timestampdiff(year, dob, curdate()) < 18 then 'child'
            when timestampdiff(year, dob, curdate()) between 18 and 60 then 'adult'
            else 'senior'
        end as age_group,
        count(*) as total_patients
    from patients
    group by age_group;
end //
delimiter ;
call patientagegroups();
