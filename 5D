create procedure seniorpatientscursor()
begin
    declare done int default false;
    declare pname varchar(50);
    declare phone varchar(15);
    declare pdob date;
    declare cur cursor for
        select patientname, phonenumber, dob from patients;
    declare continue handler for not found set done = true;
    open cur;
    read_loop: loop
        fetch cur into pname, phone, pdob;
        if done then
            leave read_loop;
        end if;
        if timestampdiff(year, pdob, curdate()) > 60 then
            select pname as name, phone as phone;
        end if;
    end loop;
    close cur;
end //
delimiter ;
call seniorpatientscursor();
