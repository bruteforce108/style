(3, 1, 1, 200);
select 
    m.category,
    sum(oi.quantity * oi.unit_price) as total_sales
from orderitems oi
join menu m on oi.item_id = m.item_id
group by m.category;
delimiter //

create procedure getorderdetails(in oid int)
begin
    select 
        o.order_id,
        c.name as customer_name,
        m.item_name,
        oi.quantity,
        oi.unit_price
    from orders o
    join customers c on o.customer_id = c.customer_id
    join orderitems oi on o.order_id = oi.order_id
    join menu m on oi.item_id = m.item_id
    where o.order_id = oid;
end //	

delimiter ;

call getorderdetails(1);
select 
    o.order_id,
    c.name,
    o.order_date_time
from orders o
join customers c on o.customer_id = c.customer_id;
select m.item_name
from menu m
left join orderitems oi on m.item_id = oi.item_id
where oi.item_id is null;
create view top_selling_items as
select 
    m.item_name,
    sum(oi.quantity) as total_sold
from orderitems oi
join menu m on oi.item_id = m.item_id
group by m.item_name
order by total_sold desc
limit 3;

select * from top_selling_items;
select *
from orders
where date(order_date_time) = curdate();
delimiter //

create procedure dailysalessummary()
begin
    declare done int default false;
    declare o_date date;
    declare total decimal(10,2);

    declare cur cursor for
        select date(o.order_date_time),
               sum(oi.quantity * oi.unit_price)
        from orders o
        join orderitems oi on o.order_id = oi.order_id
        group by date(o.order_date_time);

    declare continue handler for not found set done = true;

    open cur;

    read_loop: loop
        fetch cur into o_date, total;

        if done then
            leave read_loop;
        end if;

        select o_date as order_date, total as total_sales;
    end loop;

    close cur;
end //

delimiter ;


call dailysalessummary(); 
