DELIMITER //
CREATE FUNCTION isoutofstock(pid int)
RETURNS varchar(10)
DETERMINISTIC
BEGIN
    DECLARE total_qty int;
    SELECT ifnull(sum(quantity_in_stock), 0)
    INTO total_qty
    FROM inventory
    WHERE product_id = pid;
    IF total_qty = 0 THEN
        RETURN 'yes';
    ELSE
        RETURN 'no';
    END IF;
END //
DELIMITER ;
SELECT isoutofstock(101) AS out_of_stock;
SELECT 
    o.order_id,
    o.customer_id,
    o.order_date,
    s.tracking_number
FROM orders o
LEFT JOIN shipments s ON o.order_id = s.order_id;
SELECT name, price
FROM products
WHERE category_id IN (
    SELECT category_id 
    FROM categories 
    WHERE category_name = 'washing machines'
)
OR price > 900;
SELECT p.name
FROM products p
JOIN categories c ON p.category_id = c.category_id
WHERE c.category_name = 'kitchen';
SELECT count(*) AS total_orders
FROM orders;
DELIMITER //
CREATE PROCEDURE showproducts()
BEGIN
    DECLARE done int default false;
    DECLARE pname varchar(50);
    DECLARE pprice decimal(10,2);
    DECLARE cur cursor for
        SELECT name, price FROM products;
    DECLARE continue handler for not found set done = true;
    OPEN cur;
    read_loop: LOOP
        FETCH cur INTO pname, pprice;
        IF done THEN
            LEAVE read_loop;
        END IF;
        SELECT pname AS product_name, pprice AS price;
    END LOOP;
    CLOSE cur;
END //
DELIMITER ;
CALL showproducts();
SELECT 
    max(price) AS max_price,
    min(price) AS min_price
FROM products;
