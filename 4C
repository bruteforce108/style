create table products_backup (
    product_id int,
    name varchar(50),
    description varchar(100),
    price decimal(10,2),
    category_id int,
    deleted_at timestamp default current_timestamp
);
delimiter //

create trigger backup_product_delete
before delete on products
for each row
begin
    insert into products_backup
    (product_id, name, description, price, category_id)
    values
    (old.product_id, old.name, old.description, old.price, old.category_id);
end //

delimiter ;
create view product_stock_view as
select 
    p.name as product_name,
    i.quantity_in_stock,
    w.warehouse_name
from products p
join inventory i on p.product_id = i.product_id
join warehouses w on i.warehouse_id = w.warehouse_id;

