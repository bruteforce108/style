select 
    p.name,
    sum(i.quantity_in_stock) as total_stock
from products p
join inventory i on p.product_id = i.product_id
group by p.name;
select 
    c.category_name,
    avg(p.price) as avg_price
from products p
join categories c on p.category_id = c.category_id
group by c.category_name;
select name, price
from products
where category_id in (
    select category_id 
    from categories 
    where category_name = 'refrigerators'
)
or price > 1000;
create procedure productstockcursor()
begin
    declare done int default false;
    declare pname varchar(50);
    declare total int;

    declare cur cursor for
        select p.name, sum(i.quantity_in_stock)
        from products p
        join inventory i on p.product_id = i.product_id
        group by p.name;

    declare continue handler for not found set done = true;

    open cur;

    read_loop: loop
        fetch cur into pname, total;

        if done then
            leave read_loop;
        end if;

        select pname as product_name, total as total_stock;
    end loop;

    close cur;
end //

delimiter ;

call productstockcursor();
select 
    w.warehouse_name,
    sum(i.quantity_in_stock) as total_stock
from warehouses w
join inventory i on w.warehouse_id = i.warehouse_id
group by w.warehouse_name
having sum(i.quantity_in_stock) < 50;
